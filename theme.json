{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "64rem",
      "wideSize": "100rem"
    },
    "color": {
      "palette": [
        { "slug": "primary-darkest", "color": "#07124a", "name": "Primary darkest" },
        { "slug": "primary-darker", "color": "#0d2499", "name": "Primary darker" },
        { "slug": "primary", "color": "#005ea2", "name": "Primary" },
        { "slug": "white", "color": "#ffffff", "name": "White" }
      ]
    }
  },
  "templateParts": [
    { "name": "usa-banner", "title": "USA Banner", "area": "header" },
    { "name": "header", "title": "Site header (nav)", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "page-no-title", "title": "Page (no title)", "postTypes": ["page"] },
    { "name": "page-explore", "title": "Explore page", "postTypes": ["page"] },
    { "name": "page-program-overview", "title": "Program Overview page", "postTypes": ["page"] },
    { "name": "page-fusion-toolkit", "title": "Fusion Toolkit page", "postTypes": ["page"] },
    { "name": "page-page-layouts", "title": "Page layouts library", "postTypes": ["page"] },
    { "name": "page-landing-layout", "title": "Landing page layout", "postTypes": ["page"] },
    { "name": "page-platform-article", "title": "Platform article page", "postTypes": ["page"] },
    { "name": "page-shared-services", "title": "Shared Services catalog", "postTypes": ["page"] },
    { "name": "page-shared-service-article", "title": "Shared Service article page", "postTypes": ["page"] },
    { "name": "page-about-benefits", "title": "About Benefits page", "postTypes": ["page"] },
    { "name": "page-about-section", "title": "About Hybrid Cloud section page", "postTypes": ["page"] }
  ]
}
